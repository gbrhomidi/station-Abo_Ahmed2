<?xml version="1.0" encoding="utf-8"?>
<!--
  ═══════════════════════════════════════════════════════════════════
  محطة أبو أحمد - إعدادات أمان الشبكة (Network Security Config)
  ═══════════════════════════════════════════════════════════════════

  التحديثات الأمنية:
  1. منع الاتصالات غير المشفرة (Cleartext) بشكل افتراضي
  2. استثناء محدد للخادم المحلي فقط (127.0.0.1 / localhost)
  3. Certificate Pinning لـ Gemini API
  4. Trust Anchors محدودة (System + User)
  5. إعدادات Debuggable منفصلة

  ⚠️ تحذير: لا تعدل هذا الملف إلا إذا كنت تعرف ما تفعله
  ═══════════════════════════════════════════════════════════════════
-->
<network-security-config>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- الإعدادات الأساسية - تطبق على جميع الاتصالات              -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- الثقة بالشهادات النظامية فقط -->
            <certificates src="system"/>
            <!-- إلغاء التعليق التالي فقط إذا كان المستخدم يثبت شهاداته الخاصة -->
            <!-- <certificates src="user"/> -->
        </trust-anchors>

        <!-- منع الاتصالات التي تستخدم شهادات قديمة/ضعيفة -->
        <pin-set expiration="2027-01-01">
            <!-- 
                Certificate Pinning لـ Gemini API
                SHA-256 hashes للشهادات الرئيسية لـ Google APIs
                يمكن الحصول على القيم الصحيحة باستخدام:
                openssl s_client -connect generativelanguage.googleapis.com:443 | openssl x509 -pubkey -noout | openssl pkey -pubin -outform der | openssl dgst -sha256 -binary | openssl enc -base64
            -->
            <pin digest="SHA-256">Vfd95KMHNCyP4qPm+nrX+Ir2v8E8Ihr8aRr4D45E1gk=</pin>
            <pin digest="SHA-256">Y9mvm0exBk1JoQ57f9Vm28eKZ71WHYAPSfwAqo3eT0I=</pin>
            <!-- Pin احتياطي في حالة تغيير الشهادة -->
            <pin digest="SHA-256">AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=</pin>
        </pin-set>

        <!-- منع الاتصال إذا فشل Certificate Pinning -->
        <cleartextTrafficPermitted>false</cleartextTrafficPermitted>
    </base-config>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- استثناء الخادم المحلي (NanoHTTPD)                           -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- 
        السبب: WebView يحتاج للاتصال بالخادم المحلي عبر HTTP
        المخاطر: منخفضة (اتصال داخلي فقط، لا يمر عبر الشبكة)
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">::1</domain>  <!-- IPv6 localhost -->

        <!-- لا نطبق Certificate Pinning على الاتصالات المحلية -->
        <pin-set>
            <!-- فارغ - لا pinning للخادم المحلي -->
        </pin-set>

        <!-- الثقة بجميع الشهادات للخادم المحلي -->
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </domain-config>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- إعدادات خاصة لـ Gemini API                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <domain-config>
        <domain includeSubdomains="true">generativelanguage.googleapis.com</domain>
        <domain includeSubdomains="true">googleapis.com</domain>

        <!-- منع الاتصال غير المشفر تماماً -->
        <cleartextTrafficPermitted>false</cleartextTrafficPermitted>

        <!-- Certificate Pinning إلزامي -->
        <pin-set expiration="2027-01-01">
            <pin digest="SHA-256">Vfd95KMHNCyP4qPm+nrX+Ir2v8E8Ihr8aRr4D45E1gk=</pin>
            <pin digest="SHA-256">Y9mvm0exBk1JoQ57f9Vm28eKZ71WHYAPSfwAqo3eT0I=</pin>
            <pin digest="SHA-256">AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=</pin>
        </pin-set>

        <!-- منع الاتصال إذا فشل التحقق -->
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </domain-config>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- إعدادات Debug (تُستخدم فقط في builds التطوير)             -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- 
        ملاحظة: هذه الإعدادات تُستخدم فقط عند:
        - android:debuggable="true"
        - أو عند استخدام build variant "debug"
    -->
    <debug-overrides>
        <trust-anchors>
            <!-- في وضع التطوير فقط: السماح بشهادات المستخدم -->
            <certificates src="user"/>
            <certificates src="system"/>
        </trust-anchors>

        <!-- في وضع التطوير: السماح بـ cleartext للاختبار -->
        <cleartextTrafficPermitted>true</cleartextTrafficPermitted>
    </debug-overrides>

</network-security-config>
