<?xml version="1.0" encoding="utf-8"?>
<!--
  ═══════════════════════════════════════════════════════════════
   محطة أبو أحمد - قواعد استخراج وحماية البيانات (مُحدّثة)
   data_extraction_rules.xml
  ═══════════════════════════════════════════════════════════════

  ✅ تم التحديث وفق معايير الأمان:
  - جميع قواعد البيانات والإعدادات الحساسة مستثناة من النسخ الاحتياطي.
  - ملفات النسخ الاحتياطي وتقارير الأعطال مستثناة من السحابة.
  - نقل الجهاز يستثني البيانات الأساسية فقط، لحماية الخصوصية.
  ═══════════════════════════════════════════════════════════════
-->
<data-extraction-rules>

    <!-- ═══════════════ النسخ الاحتياطي السحابي (Cloud Backup) ═══════════════ -->
    <cloud-backup>
        <!-- ❌ الإعدادات المشتركة (قد تحتوي على رموز جلسات أو توكنات) -->
        <exclude domain="sharedpref" path="."/>
        <!-- ❌ قاعدة البيانات (بيانات العملاء والمعاملات الحساسة) -->
        <exclude domain="database" path="."/>
        <!-- ❌ ملفات النسخ الاحتياطي الداخلية -->
        <exclude domain="file" path="backups/"/>
        <!-- ❌ تقارير الأعطال (قد تسرب معلومات الجهاز أو مسارات ملفات حساسة) -->
        <exclude domain="file" path="crashes/"/>
    </cloud-backup>

    <!-- ═══════════════ نقل البيانات بين الأجهزة (Device Transfer) ═══════════════ -->
    <device-transfer>
        <!-- ❌ الإعدادات المشتركة -->
        <exclude domain="sharedpref" path="."/>
        <!-- ❌ قاعدة البيانات -->
        <exclude domain="database" path="."/>
    </device-transfer>

</data-extraction-rules>
