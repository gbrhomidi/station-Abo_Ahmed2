<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- سمة بسيطة متوافقة مع AppCompatActivity -->
    <style name="Theme.MyApplication" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- ألوان الهوية -->
        <item name="android:windowBackground">@color/diesel_blue</item>
        <item name="android:statusBarColor">@color/diesel_blue</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- منع معاينة التطبيق في Recent Apps -->
        <item name="android:windowDisablePreview">true</item>
        
        <!-- ألوان Material -->
        <item name="colorPrimary">@color/diesel_blue</item>
        <item name="colorPrimaryDark">@color/diesel_dark</item>
        <item name="colorAccent">@color/diesel_gold</item>
    </style>
</resources>
