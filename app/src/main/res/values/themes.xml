<?xml version="1.0" encoding="utf-8"?>
<!--
   ═══════════════════════════════════════════════════════════════
   محطة أبو أحمد - ملف السمات (Themes)
   ═══════════════════════════════════════════════════════════════
   
   الإصدار: 2.0 – متوافق مع Material Components و AppCompatActivity
   التحديثات:
   - استخدام Theme.MaterialComponents.Light.NoActionBar (متوافق مع AppCompat)
   - إضافة ألوان Material Design 3 (colorPrimary, colorSecondary, إلخ)
   - الحفاظ على ألوان الهوية (diesel_blue, diesel_gold)
   - أمان بصري: منع معاينة التطبيق في Recent Apps
   ═══════════════════════════════════════════════════════════════
-->
<resources>
    <!-- السمة الأساسية للتطبيق – Material Components مع دعم AppCompatActivity -->
    <style name="Theme.MyApplication" parent="Theme.MaterialComponents.Light.NoActionBar">
        
        <!-- ═══ ألوان Material Design 3 (M3) ═══ -->
        <!-- اللون الأساسي (Primary) – المستخدم في شريط الحالة والأزرار الرئيسية -->
        <item name="colorPrimary">@color/diesel_blue</item>
        <item name="colorPrimaryVariant">@color/diesel_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- اللون الثانوي (Secondary) – يستخدم للعناصر المميزة مثل الأزرار الثانوية -->
        <item name="colorSecondary">@color/diesel_gold</item>
        <item name="colorSecondaryVariant">@color/diesel_gold</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- ألوان الخلفية والسطح -->
        <item name="android:windowBackground">@color/diesel_blue</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        
        <!-- ألوان الأخطاء والتحذيرات -->
        <item name="colorError">@color/red</item>
        <item name="colorOnError">@color/white</item>
        
        <!-- ═══ إعدادات شريط الحالة والتنقل ═══ -->
        <item name="android:statusBarColor">@color/diesel_blue</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:forceDarkAllowed">true</item>
        
        <!-- ═══ أمان بصري: منع معاينة التطبيق (windowDisablePreview) ═══ -->
        <!-- يمنع ظهور لقطة شاشة للتطبيق في شاشة المهام المتعددة (Recent Apps) -->
        <item name="android:windowDisablePreview">true</item>
        
        <!-- ═══ إعدادات إضافية لتحسين المظهر ═══ -->
        <!-- استخدام الخطوط الافتراضية (يمكن تغييرها حسب الرغبة) -->
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/diesel_gold</item>
        
        <!-- تفعيل الرسوم المتحركة للانتقال بين الشاشات -->
        <item name="android:windowAnimationStyle">@style/Animation.AppCompat</item>
        
        <!-- إعدادات الـ Toolbar (إذا تم استخدامه) -->
        <item name="toolbarStyle">@style/Widget.MaterialComponents.Toolbar.Primary</item>
        
        <!-- إعدادات الـ Button (نمط Material) -->
        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button</item>
        
        <!-- إعدادات الـ CardView (إذا تم استخدامه) -->
        <item name="cardViewStyle">@style/Widget.MaterialComponents.CardView</item>
    </style>
</resources>
